# Copy to .env and fill with your Supabase project values (Vite requires VITE_ prefix).
VITE_SUPABASE_URL=your_project_url
VITE_SUPABASE_ANON_KEY=your_public_key

# Optional: override API / WebSocket (defaults work for local dev).
# VITE_API_BASE=http://localhost:4000/api
# VITE_WS_URL=ws://localhost:4000/live-ws
